datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model wtp_logs {
  id           Int      @id @default(autoincrement())
  debit_inlet  Float
  debit_outlet Float
  nutrisi      Float?
  chemical     Float?
  uploaded_by  String?
  created_at   DateTime @default(now())
}

model wwtp_logs {
  id           Int      @id @default(autoincrement())
  do           Float
  debit_inlet  Float
  debit_outlet Float
  nh3_n        Float
  ph           Float
  uploaded_by  String?
  created_at   DateTime @default(now())
}

model users {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  role     String // Isinya nanti: "admin" atau "engineer"
}
